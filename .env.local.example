# Supabase — copie para .env.local e preencha com o seu projeto.
# URL e anon key são públicas (podem ir ao client).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Chave secreta — SOMENTE server-side (Netlify Functions, migrations, admin).
# Nunca commitar. Nunca expor no client.
SUPABASE_SERVICE_ROLE_KEY=

